<?xml version="1.0" encoding="UTF-8"?>

<sequences xmlns="http://ws.apache.org/ns/synapse">

   
    <sequence name="mcpProcessingSequence">
        <log level="full" separator="=== MCP Command Received ==="/>
        
    
        <property name="mcp.method" expression="json-eval($.method)"/>
        <property name="mcp.params" expression="json-eval($.params)"/>
        
        
        <class name="org.wso2.carbon.inbound.SSE.SSEMessageConsumer"/>
        
       
    </sequence>

   
    <sequence name="mcpErrorSequence">
        <log level="full" separator="=== MCP Error ==="/>
        
        
        <payloadFactory media-type="json">
            <format>
                {
                    "jsonrpc": "2.0",
                    "error": {
                        "code": -32603,
                        "message": "Internal server error"
                    },
                    "id": null
                }
            </format>
        </payloadFactory>
        
      
    </sequence>

</sequences>
