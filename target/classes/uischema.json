{
  "id": "org.wso2.carbon.inbound.SSE.SSEMessageConsumer",
  "name": "sseInbound",
  "type": "event-integration",
  "title": "SSE Inbound Endpoint",
  "help": "Configure Server-Sent Events (SSE) Consumer Settings",
  "elements": [
    {
      "type": "attributeGroup",
      "value": {
        "groupName": "Generic",
        "elements": [
          {
            "type": "attribute",
            "value": {
              "name": "name",
              "displayName": "Event Integration Name",
              "inputType": "string",
              "required": "true",
              "helpTip": "Unique identifier for the SSE event integration."
            }
          },
          {
            "type": "attribute",
            "value": {
              "name": "class",
              "displayName": "Class Name",
              "inputType": "string",
              "required": "true",
              "hidden": true,
              "defaultValue": "org.wso2.carbon.inbound.SSE.SSEMessageConsumer"
            }
          },
          {
            "type": "attribute",
            "value": {
              "name": "generateSequences",
              "displayName": "Automatically generate sequences",
              "inputType": "checkbox",
              "defaultValue": true
            }
          },
          {
            "type": "attribute",
            "value": {
              "name": "sequence",
              "displayName": "Injecting Sequence Name",
              "inputType": "keyOrExpression",
              "keyType": "sequence",
              "required": "true",
              "enableCondition": [
                {
                  "generateSequences": false
                }
              ],
              "helpTip": "Sequence to inject the SSE message"
            }
          },
          {
            "type": "attribute",
            "value": {
              "name": "onError",
              "displayName": "Error Sequence Name",
              "inputType": "keyOrExpression",
              "keyType": "sequence",
              "required": "true",
              "enableCondition": [
                {
                  "generateSequences": false
                }
              ],
              "helpTip": "Error sequence to invoke on fault"
            }
          },
          {
            "type": "attribute",
            "value": {
              "name": "suspend",
              "displayName": "Suspend Inbound",
              "inputType": "boolean",
              "defaultValue": false,
              "hidden": true,
              "required": "false",
              "helpTip": "Suspend Inbound"
            }
          }
        ]
      }
    },
    {
      "type": "attributeGroup",
      "value": {
        "groupName": "Inbound Functional",
        "elements": [
          {
            "type": "attribute",
            "value": {
              "name": "sequential",
              "displayName": "Execute sequentially",
              "inputType": "boolean",
              "defaultValue": true,
              "required": "false",
              "helpTip": "The behaviour when executing the given sequence."
            }
          },
          {
            "type": "attribute",
            "value": {
              "name": "coordination",
              "displayName": "Coordination",
              "inputType": "boolean",
              "defaultValue": true,
              "required": "false",
              "helpTip": "In a clustered setup, this will run the inbound only in a single worker node."
            }
          }
        ]
      }
    },
    {
      "type": "attributeGroup",
      "value": {
        "groupName": "SSE Configuration",
        "elements": [
          {
            "type": "attribute",
            "value": {
              "name": "endpointUrl",
              "displayName": "SSE Endpoint URL",
              "inputType": "string",
              "required": true,
              "helpTip": "The URL of the SSE stream endpoint. Example: https://example.com/events"
            }
          },
          {
            "type": "attribute",
            "value": {
              "name": "contentType",
              "displayName": "Content Type",
              "inputType": "string",
              "defaultValue": "application/json",
              "required": false,
              "helpTip": "The content type of the messages (e.g., application/json, text/plain)"
            }
          },
          {
            "type": "attribute",
            "value": {
              "name": "headers",
              "displayName": "Custom Headers",
              "inputType": "string",
              "required": false,
              "helpTip": "Custom HTTP headers in format: Header1=Value1,Header2=Value2"
            }
          },
          {
            "type": "attribute",
            "value": {
              "name": "reconnectIntervalMs",
              "displayName": "Reconnect Interval (ms)",
              "inputType": "string",
              "defaultValue": "5000",
              "required": false,
              "helpTip": "Time to wait before attempting to reconnect after connection loss (milliseconds)"
            }
          },
          {
            "type": "attribute",
            "value": {
              "name": "readTimeoutMs",
              "displayName": "Read Timeout (ms)",
              "inputType": "string",
              "defaultValue": "0",
              "required": false,
              "helpTip": "Read timeout in milliseconds. 0 means no timeout."
            }
          }
        ]
      }
    }
  ]
}
